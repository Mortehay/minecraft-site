# ── Supabase (Auth + Storage + DB) ────────────────────────────────────
# Local dev:  use your Supabase project URL and anon key
# Production: replace with your production project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── App Settings ───────────────────────────────────────────────────────
# Email address that will be automatically assigned the 'admin' role
# on first sign-up / next login.
ADMIN_EMAIL=admin@example.com

# ── Local PostgreSQL (dev only, not used in production) ───────────────
DB_PASSWORD=password

# ── MailHog SMTP (dev only) ───────────────────────────────────────────
# Configure Supabase Auth custom SMTP to point here for local dev:
#   Host: host.docker.internal  (or mailhog if in same compose network)
#   Port: 1025
#   No authentication needed
# MailHog Web UI: http://localhost:8025