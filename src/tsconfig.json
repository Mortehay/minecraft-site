{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "module": "ESNext",
    /* Change 'bundler' to 'node' if TS version < 5.0 */
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "useDefineForClassFields": true,
    /* Ensure you aren't accidentally excluding your source files */
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite-env.d.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}